<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">

    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="LOG_FILE">logs/app.log</Property>
    </Properties>

    <Appenders>
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- syncSend=false: asenkron gönderim — Kafka erişilemese bile uygulama bloklanmaz -->
        <Kafka name="KafkaAppender" topic="application-logs" syncSend="false">
            <Property name="bootstrap.servers">${env:KAFKA_BOOTSTRAP_SERVERS:-localhost:9092}</Property>
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Kafka>

        <RollingFile name="FileAppender"
                     fileName="${LOG_FILE}"
                     filePattern="logs/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- ApplicationLogConsumer ve OpenSearch paketi KafkaAppender'dan muaf tutulur.
             Bu logger com.ticketsystem'den önce tanımlanmalıdır; Log4j2 en özgül eşleşmeyi seçer.
             Amaç: consumer'ın kendi logları Kafka'ya gidip recursive döngü oluşturmasın. -->
        <Logger name="com.ticketsystem.opensearch" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Kafka internal logları KafkaAppender'a gitmesin — sonsuz döngü riski -->
        <Logger name="org.apache.kafka" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>
        <Logger name="org.springframework.kafka" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Uygulama kodu — tam görünürlük; application logları Kafka'ya da iletilir -->
        <Logger name="com.ticketsystem" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
            <AppenderRef ref="KafkaAppender"/>
        </Logger>

        <!-- Spring Framework genel -->
        <Logger name="org.springframework" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Spring Security — her request'te auth filter logu basar, WARN'a çekildi -->
        <Logger name="org.springframework.security" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Hibernate genel — SQL show-sql: true ile ayrıca yönetiliyor -->
        <Logger name="org.hibernate" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Hibernate SQL — application.yaml show-sql: true'nun Log4j2 karşılığı -->
        <Logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- jBPM process engine — INFO'da çok verbose -->
        <Logger name="org.jbpm" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Drools kural motoru — jBPM iç bileşeni -->
        <Logger name="org.drools" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- KIE container lifecycle -->
        <Logger name="org.kie" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Flyway migration adımları bilgilendirici -->
        <Logger name="org.flywaydb" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Root — tanımlanmayan tüm logger'lar -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Root>
    </Loggers>

</Configuration>
