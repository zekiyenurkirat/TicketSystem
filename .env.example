# ──────────────────────────────────────────────────────────────
# TicketSystem — Docker ortam değişkenleri şablonu
#
# Kullanım:
#   cp .env.example .env
#   .env dosyasını düzenleyerek gerçek değerleri girin.
#
# .env dosyası .gitignore ile GitHub'a gitmez — güvenle kullanın.
# ──────────────────────────────────────────────────────────────

# PostgreSQL kullanıcı adı
DB_USERNAME=postgres

# PostgreSQL şifresi (güçlü bir şifre belirleyin)
DB_PASSWORD=postgres123

# JWT imzalama anahtarı
# En az 32 karakter, rastgele ve tahmin edilemez olmalıdır.
# Örnek üretmek için: openssl rand -hex 32
JWT_SECRET=change-me-to-a-very-long-random-secret-key-minimum-32-chars
